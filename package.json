{
  "name": "test-automation-projects",
  "version": "1.0.0",
  "description": "Cypress projects portofolio containing test plan, test scope, test cases, test steps and more.",
  "main": "cypress.config.js",
  "scripts": {
    "pretest": "rimraf cypress/reports mergedreports.json",
    "test": "npm run cypress-test && npm run posttest",
    "cypress-test": "npx cypress run",
    "posttest": "npm run merge-reports && npm run generate-htmlreport",
    "merge-reports": "mochawesome-merge cypress/reports/*.json > mergedreports.json",
    "generate-htmlreport": "npx marge ./mergedreports.json --reportDir ./ --inline"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ElenaAlina/test-automation-projects.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ElenaAlina/test-automation-projects/issues"
  },
  "homepage": "https://github.com/ElenaAlina/test-automation-projects#readme",
  "dependencies": {
    "rimraf": "^6.1.3"
  },
  "devDependencies": {
    "cypress": "^15.14.2",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^4.4.1",
    "mochawesome-report-generator": "^6.3.2"
  }
}
